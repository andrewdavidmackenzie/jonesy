{
  "problemMatcher": [
    {
      "owner": "jonesy",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^\\s*(?:└──)?\\s*-->\\s+(.+):(\\d+):(\\d+)\\s+\\[([A-Z]+\\d+):\\s+(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        }
      ]
    }
  ]
}
